# ─── Frontend (React) ────────────────────────────────────────────────────────
# Set REACT_APP_AI_PROVIDER=openai and REACT_APP_AI_ENABLED=true in production.
# Leave REACT_APP_AI_API_BASE empty — the app uses relative /api/... paths which
# work on Vercel (same origin) and locally via the CRA dev proxy.
REACT_APP_AI_PROVIDER=mock
REACT_APP_AI_ENABLED=false
REACT_APP_AI_API_BASE=
REACT_APP_AI_MODEL=gpt-4.1-mini
REACT_APP_AI_TIMEOUT_MS=8000

# ─── Backend (Vercel serverless / local Express server) ──────────────────────
# Set these in the Vercel dashboard under Project → Settings → Environment Variables.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Local dev only — not used on Vercel.
AI_SERVER_PORT=8787

# Strava OAuth (api/_lib/stravaService.js). STRAVA_REDIRECT_URI must exactly match
# the "Authorization Callback Domain" configured in the Strava API app settings.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=

# Crash reporting (production only, when set)
REACT_APP_SENTRY_DSN=https://xxx@sentry.io/yyy
