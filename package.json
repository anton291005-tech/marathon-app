{
  "name": "marathon-app",
  "version": "0.1.0",
  "private": true,
  "homepage": ".",
  "proxy": "http://localhost:8787",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@capacitor/app": "^8.0.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@capgo/capacitor-health": "^8.4.2",
    "@sentry/react": "^10.58.0",
    "@supabase/supabase-js": "^2.106.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "i18next": "23.15.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "14.1.3",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "dev": "react-scripts start",
    "start": "react-scripts start",
    "start:api": "node server/index.js",
    "start:full": "concurrently \"npm run start:api\" \"npm start\"",
    "build": "CI=false BUILD_PATH=dist react-scripts build",
    "postbuild": "node -e \"if (!process.env.VERCEL) { require('child_process').execSync('npx cap sync', {stdio:'inherit'}); }\"",
    "build:verify": "npm run build && node -e \"require('fs').existsSync('dist/index.html') || (console.error('Missing dist/index.html after build.'), process.exit(1))\"",
    "verify:build": "node scripts/checkBuild.js",
    "verify:transaction": "node scripts/featureTransaction.js",
    "verify:atomic": "node scripts/enforceAtomicChange.js",
    "verify:diff": "node scripts/checkDiffSize.js",
    "verify:strict": "npm run verify:transaction && npm run verify:atomic && npm run verify:diff && node scripts/enforceBuildAndTest.js",
    "commit:transaction": "npm run verify:strict && node scripts/commitTransaction.js",
    "build:ios-safe": "rm -rf dist build && npm run build && node scripts/verify-web-build.js",
    "verify:cap-web": "node scripts/verify-web-build.js",
    "cap:sync": "npm run build && npm run verify:cap-web",
    "cap:ios": "npm run build && npm run verify:cap-web && npx cap open ios",
    "ios": "CI=false DISABLE_ESLINT_PLUGIN=true npm run build && npx cap sync ios && npx cap open ios",
    "ios:prod": "npm run build:ios-safe && npx cap open ios",
    "deploy:ios": "npx cap sync ios && open ios/App/App.xcworkspace",
    "clean:ios": "rm -rf ios/App/DerivedData && rm -rf ios/App/build && rm -rf dist && rm -rf build && rm -rf node_modules/.cache",
    "test": "react-scripts test",
    "test:long-run-cap": "node scripts/test-long-run-cap.js",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "src/**/*.{ts,tsx}"
        ],
        "excludedFiles": [
          "src/auxiliary/**/*.{ts,tsx}"
        ],
        "rules": {
          "no-restricted-imports": [
            "error",
            {
              "patterns": [
                {
                  "group": [
                    "**/auxiliary/**",
                    "**/auxiliary/*"
                  ],
                  "message": "SSOT-facing code must not import quarantined experimental modules under src/auxiliary."
                }
              ]
            }
          ]
        }
      },
      {
        "files": [
          "src/**/*.{ts,tsx}"
        ],
        "excludedFiles": [
          "src/core/time/timeSystem.ts",
          "**/*.test.ts",
          "**/*.test.tsx"
        ],
        "rules": {
          "no-restricted-syntax": [
            "error",
            {
              "selector": "NewExpression[callee.name='Date'][arguments.length=0]",
              "message": "Use getAppNow() from src/core/time/timeSystem.ts (forbidden: new Date() without arguments outside timeSystem)."
            },
            {
              "selector": "CallExpression[callee.object.name='Date'][callee.property.name='now']",
              "message": "Use getAppNowEpochMs() from src/core/time/timeSystem.ts."
            }
          ]
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "ts-node": "^10.9.2"
  }
}
